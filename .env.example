# Odoo — Backend de ecommerce
# URL del servidor Odoo (sin barra al final)
ODOO_URL=https://odoo.dailymp.tech
# Nombre de la base de datos Odoo
ODOO_DB=dailymp
# Usuario Odoo con rol Sales/User (sin acceso admin)
ODOO_LOGIN=maruchy-api
# API Key generada en Odoo: Ajustes > Técnico > Claves API
ODOO_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL del sitio (sin barra al final)
SITE_URL=https://maruchy.es
