  const modal = document.getElementById('bag-modal') as HTMLElement;
  const modalImg = document.getElementById('bag-modal-img') as HTMLImageElement;
  const modalTitle = document.getElementById('bag-modal-title') as HTMLElement;
  const modalCategory = document.getElementById('bag-modal-category') as HTMLElement;
  const modalDescription = document.getElementById('bag-modal-description') as HTMLElement;
  const modalWhatsapp = document.getElementById('bag-modal-whatsapp') as HTMLAnchorElement;
  const closeBtn = document.getElementById('bag-modal-close') as HTMLElement;

  function openModal(index: number) {
    const bag = bagData[index];
    modalImg.src = bag.image;
    modalImg.alt = bag.alt;
    modalTitle.textContent = bag.title;
    modalCategory.textContent = bag.category;
    modalDescription.textContent = bag.description;
    modalWhatsapp.href = `https://wa.me/34676053518?text=Hola%20Maruchy!%20Me%20interesa%20el%20bolso%20"${encodeURIComponent(bag.title)}"`;
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-bag-index]').forEach(el => {
    el.addEventListener('click', () => {
      const index = parseInt(el.getAttribute('data-bag-index') ?? '0');
      openModal(index);
    });
  });

  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>