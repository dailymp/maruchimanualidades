---
import { getProducts } from '../lib/odoo';
import type { OdooProduct } from '../lib/odoo';

let odooProducts: OdooProduct[] = [];
try {
  odooProducts = await getProducts('Bolsos');
} catch (e) {
  console.error('Error loading bags from Odoo:', e);
}

const bagLooks = odooProducts.map((p) => ({
  id: p.id,
  price: p.list_price,
  image: `/api/product-image/${p.id}`,
  alt: p.name,
  title: p.name,
  description: p.description_sale || '',
  category: p.categ_id ? (p.categ_id[1] as string).replace('Maruchy - ', '') : 'Artesanal',
  accent: 'bg-[#f5dfcf] text-[#8b5f42]',
}));

const highlights = [
  'Colección de bolsos artesanales con acabados bordados y tejidos a mano',
  'Asas de bambú, madera y combinaciones textiles con presencia propia',
  'Modelos exclusivos para regalo, invitadas y uso diario con estilo',
  'Encargos personalizados con atención directa por WhatsApp',
];
---

<section id="bolsos" class="relative overflow-hidden py-24 lg:py-32 bg-[linear-gradient(180deg,#fffaf7_0%,#f5eee5_52%,#efe1d2_100%)]">


  <div class="relative max-w-7xl mx-auto px-6 md:px-12">
    <div class="space-y-12 xl:space-y-14">
      <div class="reveal max-w-4xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-[#e8c8c3] bg-white/70 px-4 py-1.5 text-sm font-medium uppercase tracking-[0.18em] text-[#9b6a61] shadow-soft backdrop-blur-sm">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Colección bolsos
        </span>

        <h2 class="mt-6 font-display text-4xl md:text-5xl lg:text-6xl leading-tight text-[#4d342f]">
          Bolsos artesanales exclusivos
          <em class="block text-[#b68172] not-italic">diseñados para destacar en cualquier ocasión</em>
        </h2>

        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[#6f5750] text-balance">
          Bolsos bordados y tejidos a mano con materiales seleccionados, texturas ricas y un lenguaje visual artesanal que convierte cada pieza en un complemento único.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {highlights.map((item) => (
            <div class="rounded-2xl border border-white/70 bg-white/75 px-4 py-4 text-sm leading-relaxed text-[#624d47] shadow-soft backdrop-blur-sm">
              {item}
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          {['Ganchillo', 'Bordado floral', 'Asa de bambú', 'Piezas únicas'].map((tone) => (
            <span class="rounded-full border border-[#ead8ce] bg-[#fff7f3] px-4 py-2 text-sm font-medium text-[#8f655d]">{tone}</span>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="https://wa.me/34676053518?text=Hola%20Maruchy!%20Quiero%20informaci%C3%B3n%20sobre%20los%20bolsos%20artesanales"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-[#b68172] px-8 py-4 font-medium text-white shadow-soft transition-all duration-200 hover:bg-[#a06c5e]"
            aria-label="Solicitar información sobre bolsos artesanales por WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar presupuesto
          </a>

          <a
            href="#contacto"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-[#caa193] bg-white/60 px-8 py-4 font-medium text-[#8d5f53] transition-all duration-200 hover:bg-white"
            aria-label="Ir a la sección de contacto"
          >
            Consultar disponibilidad
          </a>
        </div>
      </div>

      {bagLooks.length === 0 ? (
        <p class="text-center text-[#ad8478] py-12">Cargando colección...</p>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3 reveal">
          {bagLooks.map((look, index) => (
            <article
              class="group overflow-hidden rounded-[1.75rem] border border-white/70 bg-white/80 shadow-card backdrop-blur-sm cursor-pointer transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover"
              data-bag-index={index}
            >
              <div class="overflow-hidden relative">
                <img
                  src={look.image}
                  alt={look.alt}
                  class="aspect-[4/5] w-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.04]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-[#4d342f]/0 group-hover:bg-[#4d342f]/30 transition-all duration-300 flex items-center justify-center">
                  <div class="opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300 bg-white/90 backdrop-blur-sm rounded-full p-3 shadow-soft">
                    <svg class="w-6 h-6 text-[#b68172]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <div class="mb-3 flex items-center gap-3">
                  <span class={`rounded-full px-3 py-1 text-xs font-semibold ${look.accent}`}>{look.title}</span>
                  <span class="text-xs uppercase tracking-[0.2em] text-[#ad8478]">{look.category}</span>
                </div>
                <p class="text-sm leading-relaxed text-[#6d5650]">{look.description}</p>
                <p class="mt-3 text-xs text-[#b68172] font-medium">Haz clic para ver más detalles →</p>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Modal de Producto -->
  <div
    id="bag-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Detalles del producto"
  >
    <div class="relative w-full max-w-4xl max-h-[90vh] overflow-hidden rounded-3xl bg-white shadow-2xl flex flex-col md:flex-row">
      <button
        id="bag-modal-close"
        class="absolute top-4 right-4 z-10 text-[#4d342f]/60 hover:text-[#4d342f] bg-white/80 hover:bg-white rounded-full p-2 transition-all duration-200 shadow-soft"
        aria-label="Cerrar detalles del producto"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="md:w-1/2 bg-[#f5eee5] flex items-center justify-center p-6">
        <img
          id="bag-modal-img"
          src=""
          alt=""
          class="max-w-full max-h-[50vh] md:max-h-[70vh] object-contain rounded-2xl shadow-soft"
        />
      </div>

      <div class="md:w-1/2 p-6 md:p-8 overflow-y-auto max-h-[50vh] md:max-h-[90vh]">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span id="bag-modal-category" class="text-xs uppercase tracking-[0.2em] text-[#ad8478]"></span>
          </div>
          <h3 id="bag-modal-title" class="font-display text-3xl md:text-4xl text-[#4d342f]"></h3>
          <div id="bag-modal-description" class="text-[#6f5750] leading-relaxed whitespace-pre-line"></div>

          <div class="pt-4 border-t border-[#e8c8c3] space-y-3">
            <div class="flex items-center justify-between">
              <span id="bag-modal-price" class="font-display text-3xl font-bold text-[#4d342f]"></span>
              <span class="text-xs bg-green-50 text-green-700 border border-green-200 rounded-full px-3 py-1 font-medium">Paga al recibir</span>
            </div>

            <button
              id="bag-modal-cart"
              class="inline-flex items-center justify-center gap-2 w-full rounded-full bg-[#4d342f] px-6 py-4 font-medium text-white shadow-soft transition-all duration-200 hover:bg-[#3a2520]"
              aria-label="Añadir al carrito"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              Añadir al carrito
            </button>

            <a
              id="bag-modal-whatsapp"
              href=""
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 w-full rounded-full border border-[#caa193] bg-white/60 px-6 py-3 font-medium text-[#8d5f53] transition-all duration-200 hover:bg-white text-sm"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              ¿Tienes dudas? Escríbeme
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ bagLooks }}>
  window.__MARUCHY_BAGS = bagLooks;
</script>

<script>
  import { addItem } from '../stores/cart';

  const bagData = (window as any).__MARUCHY_BAGS as typeof bagLooks;

  const modal = document.getElementById('bag-modal');
  const modalImg = document.getElementById('bag-modal-img');
  const modalTitle = document.getElementById('bag-modal-title');
  const modalCategory = document.getElementById('bag-modal-category');
  const modalDescription = document.getElementById('bag-modal-description');
  const modalWhatsapp = document.getElementById('bag-modal-whatsapp');
  const modalCart = document.getElementById('bag-modal-cart');
  const modalPrice = document.getElementById('bag-modal-price');
  const closeBtn = document.getElementById('bag-modal-close');

  let currentBag = null;

  function openModal(index) {
    const bag = bagData[index];
    currentBag = bag;
    modalImg.src = bag.image;
    modalImg.alt = bag.alt;
    modalTitle.textContent = bag.title;
    modalCategory.textContent = bag.category;
    modalDescription.textContent = bag.description;
    modalPrice.textContent = `${bag.price.toLocaleString('es-ES')} €`;
    modalWhatsapp.href = `https://wa.me/34676053518?text=Hola%20Maruchy!%20Me%20interesa%20el%20bolso%20"${encodeURIComponent(bag.title)}"`;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    currentBag = null;
  }

  modalCart.addEventListener('click', () => {
    if (!currentBag) return;
    addItem({
      id: currentBag.id,
      name: currentBag.title,
      price: currentBag.price,
      image: currentBag.image,
    });
    modalCart.textContent = '¡Añadido!';
    setTimeout(() => {
      modalCart.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg> Añadir al carrito`;
    }, 1500);
  });

  document.querySelectorAll('[data-bag-index]').forEach(el => {
    el.addEventListener('click', () => {
      openModal(parseInt(el.getAttribute('data-bag-index') || '0'));
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
