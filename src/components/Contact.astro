---
---
<section id="contacto" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Info de contacto -->
      <div class="reveal">
        <span class="section-tag">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Contacto
        </span>

        <h2 class="section-heading mb-6">
          ¿Hablamos?<br />
          <em class="text-brand-600">Estoy aquí para ti</em>
        </h2>

        <p class="text-warm-500 text-lg leading-relaxed mb-10">
          Tanto si quieres encargar una pieza, reservar plaza en un taller, o simplemente preguntar algo, no dudes en escribirme. Respondo a todos los mensajes personalmente.
        </p>

        <!-- Canales de contacto -->
        <div class="space-y-5">
          <a
            href="https://wa.me/34600000000?text=Hola%20Maruchy!"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 bg-warm-50 rounded-2xl hover:bg-brand-50 border border-warm-100 hover:border-brand-200 transition-all duration-200 group"
            aria-label="Contactar por WhatsApp"
          >
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-green-200 transition-colors">
              <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-warm-800">WhatsApp</div>
              <div class="text-brand-600 text-sm">+34 600 000 000 · Respuesta rápida</div>
            </div>
            <svg class="w-5 h-5 text-warm-300 ml-auto group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <a
            href="https://www.instagram.com/maruchymanualidades"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 bg-warm-50 rounded-2xl hover:bg-pink-50 border border-warm-100 hover:border-pink-200 transition-all duration-200 group"
            aria-label="Seguir en Instagram"
          >
            <div class="w-12 h-12 bg-gradient-to-br from-purple-100 to-pink-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:from-purple-200 group-hover:to-pink-200 transition-colors">
              <svg class="w-6 h-6 text-pink-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-warm-800">Instagram</div>
              <div class="text-pink-500 text-sm">@maruchymanualidades</div>
            </div>
            <svg class="w-5 h-5 text-warm-300 ml-auto group-hover:text-pink-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <div class="flex items-center gap-4 p-4 bg-warm-50 rounded-2xl border border-warm-100">
            <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-warm-800">Localización</div>
              <div class="text-warm-500 text-sm">Islas Canarias, España</div>
            </div>
          </div>
        </div>

        <!-- Horario -->
        <div class="mt-8 p-5 bg-brand-50 rounded-2xl border border-brand-100">
          <h3 class="font-semibold text-warm-800 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Horario de atención
          </h3>
          <div class="space-y-1 text-sm text-warm-600">
            <div class="flex justify-between">
              <span>Lunes – Viernes</span>
              <span class="font-medium text-warm-700">9:00 – 18:00</span>
            </div>
            <div class="flex justify-between">
              <span>Sábados</span>
              <span class="font-medium text-warm-700">10:00 – 14:00</span>
            </div>
            <div class="flex justify-between">
              <span>Domingos</span>
              <span class="text-warm-400">Descanso 🌿</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulario de contacto -->
      <div class="reveal bg-warm-50 rounded-3xl p-8 border border-warm-100 shadow-soft">
        <h3 class="font-display text-2xl text-warm-900 mb-2">Envíame un mensaje</h3>
        <p class="text-warm-500 text-sm mb-8">Te respondo en menos de 24h.</p>

        <form
          name="contacto"
          action=""
          method="POST"
          class="space-y-5"
          aria-label="Formulario de contacto"
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="nombre" class="block text-sm font-medium text-warm-700 mb-1.5">Nombre <span class="text-red-400" aria-label="campo requerido">*</span></label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="given-name"
                placeholder="Tu nombre"
                class="w-full px-4 py-3 bg-white border border-warm-200 rounded-xl text-warm-800 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition-all"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-warm-700 mb-1.5">Email <span class="text-red-400" aria-label="campo requerido">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="tu@email.com"
                class="w-full px-4 py-3 bg-white border border-warm-200 rounded-xl text-warm-800 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition-all"
              />
            </div>
          </div>

          <div>
            <label for="asunto" class="block text-sm font-medium text-warm-700 mb-1.5">¿Sobre qué quieres consultar?</label>
            <select
              id="asunto"
              name="asunto"
              class="w-full px-4 py-3 bg-white border border-warm-200 rounded-xl text-warm-800 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition-all appearance-none"
            >
              <option value="">Selecciona una opción...</option>
              <option value="encargo">Encargo personalizado</option>
              <option value="taller">Reserva de taller</option>
              <option value="info">Información sobre productos</option>
              <option value="colaboracion">Colaboración</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-medium text-warm-700 mb-1.5">Mensaje <span class="text-red-400" aria-label="campo requerido">*</span></label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="4"
              placeholder="Cuéntame qué tienes en mente..."
              class="w-full px-4 py-3 bg-white border border-warm-200 rounded-xl text-warm-800 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>

          <!-- Botón submit -->
          <button
            type="submit"
            class="btn-primary w-full justify-center"
            aria-label="Enviar mensaje de contacto"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            Enviar mensaje
          </button>

          <p class="text-xs text-warm-400 text-center">
            También puedes escribirme directamente por
            <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer" class="text-brand-500 hover:text-brand-600 underline underline-offset-2">WhatsApp</a>
            o
            <a href="https://www.instagram.com/maruchymanualidades" target="_blank" rel="noopener noreferrer" class="text-pink-500 hover:text-pink-600 underline underline-offset-2">Instagram</a>.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
