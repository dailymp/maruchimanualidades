      </div>

      <!-- Columna 2: Navegación -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm tracking-wide uppercase">Navegar</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#sobre-mi" class="hover:text-brand-400 transition-colors">Sobre mí</a></li>
          <li><a href="#creaciones" class="hover:text-brand-400 transition-colors">Creaciones</a></li>
          <li><a href="#ceremonia" class="hover:text-brand-400 transition-colors">Ceremonia</a></li>
          <li><a href="#galeria" class="hover:text-brand-400 transition-colors">Galería</a></li>
          <li><a href="#testimonios" class="hover:text-brand-400 transition-colors">Testimonios</a></li>
          <li><a href="#contacto" class="hover:text-brand-400 transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Columna 3: Servicios -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm tracking-wide uppercase">Servicios</h4>
        <ul class="space-y-3 text-sm">
          <li><span class="hover:text-brand-400 transition-colors cursor-default">Creaciones artesanales</span></li>
          <li><span class="hover:text-brand-400 transition-colors cursor-default">Encargos personalizados</span></li>
          <li><span class="hover:text-brand-400 transition-colors cursor-default">Vestidos de ceremonia</span></li>
          <li><span class="hover:text-brand-400 transition-colors cursor-default">Vestidos de comunión</span></li>
          <li><span class="hover:text-brand-400 transition-colors cursor-default">Regalos especiales</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-warm-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-warm-500">
      <p>© 2025 Maruchy Manualidades. Todos los derechos reservados. Hecho con <span class="text-red-400" aria-label="amor">♥</span> en Canarias.</p>
      <div class="flex items-center gap-4">
        <p>Artesanía local · Islas Canarias · España</p>
        <span class="text-warm-700">·</span>
        <p>Creado por <a href="https://dailymp.es" target="_blank" rel="noopener noreferrer" class="text-brand-500 hover:text-brand-400 transition-colors font-medium">DailyMP</a></p>
      </div>
    </div>
