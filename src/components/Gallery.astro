---
const galleryItems = [
  {
    image: "/vestido-comunion-nina-blanco-lazo-perlas.webp",
    label: "Vestido de comunion blanco con lazo y perlas",
    size: "lg",
  },
  {
    image: "/vestido-ceremonia-nina-blanco-bordado-azahar.webp",
    label: "Vestido de ceremonia blanco bordado estilo flor de azahar",
    size: "md",
  },
  {
    image: "/vestido-ceremonia-nina-crema-volantes-flor.webp",
    label: "Vestido de ceremonia crema con volantes y flor",
    size: "md",
  },
  {
    image: "/vestido-fiesta-nina-rosa-jardin-flores.webp",
    label: "Vestido de fiesta rosa para nina en jardin de flores",
    size: "md",
  },
  {
    image: "/vestido-ceremonia-nina-vichy-rojo-jardin.webp",
    label: "Vestido vichy rojo para nina con blusa blanca",
    size: "lg",
  },
  {
    image: "/bolso-artesanal-blanco-flores.webp",
    label: "Bolso artesanal blanco con flores bordadas",
    size: "md",
  },
  {
    image: "/vestido-ceremonia-nina-rosa-empolvado-encaje.webp",
    label: "Vestido de ceremonia en rosa empolvado con encaje",
    size: "md",
  },
  {
    image: "/vestido-ceremonia-nina-amarillo-dorado-bordado.webp",
    label: "Vestido de ceremonia amarillo dorado con bordado floral",
    size: "md",
  },
  {
    image: "/bolso-artesanal-estampado-tribal-maruchy.webp",
    label: "Bolso étnico artesanal con cuentas de madera",
    size: "lg",
  },
  {
    image: "/bolso-artesanal-bordado-margaritas-bambu.webp",
    label: "Bolso bordado con margaritas y asa de bambú",
    size: "sm",
  },
  {
    image: "/bolso-artesanal-estampado-otonal-hojas.webp",
    label: "Bolso saco estampado otoñal con cuentas",
    size: "sm",
  },
  {
    image: "/bolso-artesanal-bordado-flores-perlas-madera.webp",
    label: "Bolso bordado floral con perlas y asa de madera",
    size: "md",
  },
  {
    image: "/bolso-artesanal-bordado-hojas-tropicales-bambu.webp",
    label: "Bolso tote bordado hojas tropicales con asa de bambú",
    size: "lg",
  },
  { label: "Regalo personalizado hecho a mano", bg: "bg-orange-100", emoji: "🎁", size: "sm" },
];
---
<section id="galeria" class="py-24 lg:py-32 bg-warm-50">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <span class="section-tag">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Galería
      </span>
      <h2 class="section-heading mb-4">
        Colecciones que
        <em class="text-brand-600"> enamoran</em>
      </h2>
      <p class="text-warm-500 max-w-md mx-auto text-balance">
        Un vistazo a bolsos artesanales y vestidos de ceremonia/comunion en una seleccion destacada de piezas.
      </p>
    </div>

    <!-- Masonry Grid -->
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4 reveal">
      {galleryItems.map((item, i) => (
        <div
          class={`break-inside-avoid group relative overflow-hidden rounded-2xl ${item.image ? 'bg-warm-100' : item.bg} border border-white/50 shadow-soft hover:shadow-card-hover transition-all duration-300 cursor-pointer hover:-translate-y-1`}
          style={`animation-delay: ${i * 60}ms`}
          {...(item.image ? { 'data-lightbox': item.image, 'data-label': item.label } : {})}
        >
          {item.image ? (
            <>
              <img
                src={item.image}
                alt={item.label}
                class={`w-full object-cover ${item.size === 'lg' ? 'h-56 md:h-64' : item.size === 'md' ? 'h-44 md:h-52' : 'h-36 md:h-44'} group-hover:scale-105 transition-transform duration-500`}
                loading="lazy"
                decoding="async"
              />
              <!-- Overlay hover con icono lupa -->
              <div class="absolute inset-0 bg-brand-900/0 group-hover:bg-brand-900/30 transition-all duration-300 flex items-center justify-center">
                <div class="opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300 bg-white/90 backdrop-blur-sm rounded-full p-3 shadow-soft">
                  <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                  </svg>
                </div>
              </div>
            </>
          ) : (
            <div class={`flex items-center justify-center ${item.size === 'lg' ? 'h-56 md:h-64' : item.size === 'md' ? 'h-44 md:h-52' : 'h-36 md:h-44'}`}>
              <div class="text-center p-4">
                <span class="text-5xl md:text-6xl block mb-2 group-hover:scale-110 transition-transform duration-300" aria-hidden="true">{item.emoji}</span>
                <span class="text-xs font-medium text-warm-600 opacity-0 group-hover:opacity-100 transition-opacity duration-200">{item.label}</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Lightbox -->
    <div
      id="lightbox"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4"
      role="dialog"
      aria-modal="true"
      aria-label="Imagen ampliada"
    >
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 text-white/80 hover:text-white bg-white/10 hover:bg-white/20 rounded-full p-2 transition-all duration-200"
        aria-label="Cerrar imagen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain transition-opacity duration-300"
      />
      <p id="lightbox-label" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/80 text-sm bg-black/40 backdrop-blur-sm px-4 py-2 rounded-full"></p>
    </div>

  </div>
</section>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxLabel = document.getElementById('lightbox-label') as HTMLElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLElement;

  function openLightbox(src: string, label: string) {
    lightboxImg.src = src;
    lightboxImg.alt = label;
    lightboxLabel.textContent = label;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    lightboxImg.src = '';
  }

  document.querySelectorAll('[data-lightbox]').forEach(el => {
    el.addEventListener('click', () => {
      const src = el.getAttribute('data-lightbox') ?? '';
      const label = el.getAttribute('data-label') ?? '';
      openLightbox(src, label);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
