      <li><a href="#galeria" class="block px-6 py-3.5 text-warm-700 hover:bg-brand-50 hover:text-brand-600 transition-colors font-medium" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Galería</a></li>
      <li class="px-6 py-4 border-t border-warm-100">
        <a
          href="https://wa.me/34676053518?text=Hola%20Maruchy!%20Me%20gustaría%20saber%20más%20sobre%20tus%20creaciones"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full bg-brand-600 text-white font-medium py-3 rounded-full hover:bg-brand-700 transition-colors"
