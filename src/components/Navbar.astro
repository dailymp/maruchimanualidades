<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-6 md:px-12">
  <nav class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="#inicio" class="flex items-center gap-3 group" aria-label="Maruchy Manualidades – Inicio">
      <div class="w-10 h-10 rounded-full overflow-hidden ring-2 ring-brand-200 group-hover:ring-brand-400 transition-all duration-200 shadow-soft">
        <img src="/logo-maruchy-bolsos-artesanales.jpg" alt="Logo Maruchy — Bolsos artesanales hechos a mano" class="w-full h-full object-cover" />
      </div>
      <span class="font-display text-lg text-warm-900 hidden sm:block">
        Maruchy <span class="text-brand-600">Manualidades</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      <li><a href="#sobre-mi" class="nav-link">Sobre mí</a></li>
      <li><a href="#creaciones" class="nav-link">Creaciones</a></li>
      <li><a href="#ceremonia" class="nav-link">Ceremonia</a></li>
      <li><a href="#galeria" class="nav-link">Galería</a></li>
