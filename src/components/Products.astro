---
const products = [
  {
    image: "/bolso-artesanal-bordado-margaritas-bambu.webp",
    imageAlt: "Bolso artesanal hecho a mano con bordado de margaritas y asa de bambú – Maruchy",
    name: "Bolsos Artesanales Bordados",
    description: "El sello de Maruchy. Bolsos únicos confeccionados a mano con telas seleccionadas, asas de bambú o madera y bordados exclusivos de flores, hojas y motivos naturales. Cada bolso es irrepetible — no encontrarás dos iguales en ningún lugar.",
    tags: ["⭐ Producto estrella", "Hecho a mano", "Personalizable"],
    color: "from-brand-50 to-cream-100",
    accent: "bg-brand-100 text-brand-700",
    featured: true,
  },
  {
    image: "/vestido-ceremonia-nina-crema-volantes-flor.webp",
    imageAlt: "Vestido de ceremonia para nina en color crema con volantes y lazo, confeccion artesanal",
    name: "Vestidos de Ceremonia y Comunión",
    description: "Coleccion especial para ocasiones unicas: disenos delicados en crema, rosa empolvado y dorado suave, con encajes, bordados y volantes llenos de detalle.",
    tags: ["Nueva colección", "Ceremonia", "Comunión"],
    color: "from-rose-50 to-cream-100",
    accent: "bg-rose-100 text-rose-700",
  },
  {
    emoji: "🎨",
    name: "Cuadros y Pinturas",
    description: "Arte original sobre lienzo, con técnicas mixtas y la paleta de colores de Canarias. Cada cuadro es irrepetible.",
    tags: ["Original", "Personalizable"],
    color: "from-purple-50 to-brand-50",
    accent: "bg-purple-100 text-purple-700",
  },
  {
    emoji: "🧶",
    name: "Tejidos & Ganchillo",
    description: "Cestas, accesorios y prendas tejidas a mano. Piezas funcionales con una estética artesanal que enamora.",
    tags: ["Funcional", "Hecho a mano"],
    color: "from-amber-50 to-cream-100",
    accent: "bg-amber-100 text-amber-700",
  },
  {
    emoji: "🎁",
    name: "Regalos Personalizados",
    description: "¿Buscas un regalo especial? Diseño piezas únicas para bodas, bautizos, cumpleaños y cualquier ocasión.",
    tags: ["Personalizado", "Para regalar"],
    color: "from-rose-50 to-cream-50",
    accent: "bg-rose-100 text-rose-700",
  },
  {
    emoji: "🌸",
    name: "Decoración del Hogar",
    description: "Maceteros, marcos, guirnaldas y piezas decorativas que llenan cualquier espacio de calidez y personalidad.",
    tags: ["Decoración", "Hogar"],
    color: "from-pink-50 to-brand-50",
    accent: "bg-pink-100 text-pink-700",
  },
  {
    emoji: "🪡",
    name: "Bordados & Estampados",
    description: "Técnicas de bordado a mano sobre tela, ropa y accesorios. Diseños exclusivos que no encontrarás en tiendas.",
    tags: ["Textil", "Exclusivo"],
    color: "from-teal-50 to-brand-50",
    accent: "bg-teal-100 text-teal-700",
  },
];
---
<section id="creaciones" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-tag">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
        </svg>
        Mis creaciones
      </span>
      <h2 class="section-heading mb-4">
        Bolsos artesanales<br />
        <em class="text-brand-600">y mucho más</em>
      </h2>
      <p class="text-warm-500 text-lg max-w-xl mx-auto text-balance">
        Cada categoría es un universo de posibilidades. Sea lo que sea que buscas, lo hago con amor y con los mejores materiales.
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {products.map((product, i) => (
        <article
          class={`reveal card group cursor-pointer bg-gradient-to-br ${product.color} border border-warm-100 hover:-translate-y-1 ${product.featured ? 'sm:col-span-2 lg:col-span-2' : ''}`}
          style={`animation-delay: ${i * 80}ms`}
        >
          {product.image ? (
            <>
              <!-- Imagen real para producto estrella -->
              <div class="overflow-hidden rounded-t-2xl">
                <img
                  src={product.image}
                  alt={product.imageAlt}
                  class="w-full h-96 object-cover object-center group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-6">
                <div class="flex gap-2 mb-3 flex-wrap">
                  {product.tags.map(tag => (
                    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${product.accent}`}>{tag}</span>
                  ))}
                </div>
                <h3 class="font-display text-xl text-warm-900 mb-2 group-hover:text-brand-700 transition-colors">{product.name}</h3>
                <p class="text-warm-500 text-sm leading-relaxed">{product.description}</p>
              </div>
            </>
          ) : (
            <div class="p-6">
              <!-- Emoji icon -->
              <div class="text-4xl mb-4 group-hover:animate-float inline-block" aria-hidden="true">{product.emoji}</div>
              <!-- Tags -->
              <div class="flex gap-2 mb-3 flex-wrap">
                {product.tags.map(tag => (
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${product.accent}`}>{tag}</span>
                ))}
              </div>
              <!-- Nombre -->
              <h3 class="font-display text-xl text-warm-900 mb-2 group-hover:text-brand-700 transition-colors">{product.name}</h3>
              <!-- Descripción -->
              <p class="text-warm-500 text-sm leading-relaxed">{product.description}</p>
            </div>
          )}
          <!-- Footer de la card -->
          <div class="px-6 pb-6">
            <a
              href="https://www.instagram.com/maruchymanualidades"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-brand-600 text-sm font-semibold hover:gap-3 transition-all duration-200"
              aria-label={`Ver ${product.name} en Instagram`}
            >
              Ver en Instagram
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA bottom -->
    <div class="text-center mt-12 reveal">
      <p class="text-warm-500 mb-6">¿No encuentras lo que buscas? Cuéntame tu idea y lo creamos juntas.</p>
      <a
        href="https://wa.me/34676053518?text=Hola%20Maruchy!%20Tengo%20una%20idea%20para%20una%20creación%20personalizada"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        aria-label="Solicitar creación personalizada por WhatsApp"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir creación personalizada
      </a>
    </div>
  </div>
</section>
