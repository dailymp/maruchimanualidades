---
const products = [
  {
    image: "/bolso-artesanal-bordado-margaritas-bambu.webp",
    imageAlt: "Bolso artesanal hecho a mano con bordado de margaritas y asa de bambú – Maruchy",
    name: "Bolsos Artesanales Bordados",
    description: "El sello de Maruchy. Bolsos únicos confeccionados a mano con telas seleccionadas, asas de bambú o madera y bordados exclusivos de flores, hojas y motivos naturales. Cada bolso es irrepetible — no encontrarás dos iguales en ningún lugar.",
    tags: ["⭐ Producto estrella", "Hecho a mano", "Personalizable"],
    color: "from-brand-50 to-cream-100",
    accent: "bg-brand-100 text-brand-700",
    featured: true,
    href: "#bolsos",
  },
  {
    image: "/vestido-ceremonia-nina-crema-volantes-flor.webp",
    imageAlt: "Vestido de ceremonia para niña en color crema con volantes y lazo, confección artesanal",
    name: "Vestidos de Ceremonia y Comunión",
    description: "Colección especial para ocasiones únicas: diseños delicados en crema, rosa empolvado y dorado suave, con encajes, bordados y volantes llenos de detalle.",
    tags: ["Nueva colección", "Ceremonia", "Comunión"],
    color: "from-rose-50 to-cream-100",
    accent: "bg-rose-100 text-rose-700",
    href: "#ceremonia",
  },
  {
    image: "/bolso-ganchillo-beige-lazo-madera.jpeg",
    imageAlt: "Bolso de ganchillo beige con lazo y asa de madera hecho a mano",
    name: "Bolso de Ganchillo",
    description: "Nuevo diseño de bolso de ganchillo en tono beige, con textura artesanal, asa de madera y lazo frontal para un acabado elegante y natural.",
    tags: ["Nuevo", "Ganchillo", "Bolso exclusivo"],
    color: "from-amber-50 to-cream-100",
    accent: "bg-amber-100 text-amber-700",
    href: "#bolsos",
  },
  {
    emoji: "🧶",
    name: "Ganchillo",
    description: "Piezas de ganchillo hechas a mano, cuidadas puntada a puntada para ofrecer acabados artesanales y un estilo unico.",
    tags: ["Hecho a mano", "Artesanal"],
    color: "from-amber-50 to-cream-100",
    accent: "bg-amber-100 text-amber-700",
  },
  {
    emoji: "🎁",
    name: "Diseños Personalizados",
    description: "Creaciones personalizadas adaptadas a tu idea, con asesoramiento directo para conseguir una pieza unica hecha para ti.",
    tags: ["Personalizado", "A medida"],
    color: "from-rose-50 to-cream-50",
    accent: "bg-rose-100 text-rose-700",
  },
];
---
<section id="creaciones" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-tag">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
        </svg>
        Mis creaciones
      </span>
      <h2 class="section-heading mb-4">
        Bolsos artesanales<br />
        <em class="text-brand-600">vestidos, ganchillo y diseños personalizados</em>
      </h2>
      <p class="text-warm-500 text-lg max-w-xl mx-auto text-balance">
        Trabajo solo cuatro líneas: bolsos, vestidos, ganchillo y diseños personalizados. Todo hecho con amor y materiales de calidad.
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {products.map((product, i) => (
        <article
          class={`reveal card group bg-gradient-to-br ${product.color} border border-warm-100 hover:-translate-y-1 ${product.featured ? 'sm:col-span-2 lg:col-span-2' : ''}`}
          style={`animation-delay: ${i * 80}ms`}
        >
          <a href={product.href ?? '#creaciones'} class="block h-full cursor-pointer">
          {product.image ? (
            <>
              <div class="overflow-hidden rounded-t-2xl">
                <img
                  src={product.image}
                  alt={product.imageAlt}
                  class="w-full h-96 object-cover object-center group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-6">
                <div class="flex gap-2 mb-3 flex-wrap">
                  {product.tags.map(tag => (
                    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${product.accent}`}>{tag}</span>
                  ))}
                </div>
                <h3 class="font-display text-xl text-warm-900 mb-2 group-hover:text-brand-700 transition-colors">{product.name}</h3>
                <p class="text-warm-500 text-sm leading-relaxed">{product.description}</p>
                {product.href && <span class="mt-4 inline-flex text-sm font-medium text-brand-700">Ver colección</span>}
              </div>
            </>
          ) : (
            <div class="p-6">
              <div class="text-4xl mb-4 group-hover:animate-float inline-block" aria-hidden="true">{product.emoji}</div>
              <div class="flex gap-2 mb-3 flex-wrap">
                {product.tags.map(tag => (
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${product.accent}`}>{tag}</span>
                ))}
              </div>
              <h3 class="font-display text-xl text-warm-900 mb-2 group-hover:text-brand-700 transition-colors">{product.name}</h3>
              <p class="text-warm-500 text-sm leading-relaxed">{product.description}</p>
              {product.href && <span class="mt-4 inline-flex text-sm font-medium text-brand-700">Ver colección</span>}
            </div>
          )}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
