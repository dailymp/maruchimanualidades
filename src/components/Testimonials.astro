---
const testimonials = [
  {
    name: "Ana García",
    location: "Las Palmas de G.C.",
    text: "Hice el taller de ganchillo con Maruchy y fue una experiencia increíble. Muy paciente, explica genial y crea un ambiente súper acogedor. ¡Ya me he apuntado al siguiente!",
    stars: 5,
    avatar: "AG",
    color: "bg-brand-100 text-brand-700",
  },
  {
    name: "Carmen Rodríguez",
    location: "Tenerife",
    text: "Le encargué un cuadro personalizado para regalar a mi madre en su jubilación. Maruchy capturó exactamente lo que le pedí, con una delicadeza y un detalle que me dejó sin palabras.",
    stars: 5,
    avatar: "CR",
    color: "bg-purple-100 text-purple-700",
  },
  {
    name: "Lucía Martín",
    location: "Las Palmas de G.C.",
    text: "Organizamos el taller como despedida de soltera y fue el plan perfecto. Nos reímos muchísimo, aprendimos y nos fuimos con una pieza preciosa cada una. ¡Repite fijo!",
    stars: 5,
    avatar: "LM",
    color: "bg-rose-100 text-rose-700",
  },
  {
    name: "María José Pérez",
    location: "Fuerteventura",
    text: "Los cestos de ganchillo que compré son de una calidad excepcional. Se nota el amor que pone en cada puntada. Y el envío fue rapidísimo. 100% recomendable.",
    stars: 5,
    avatar: "MJ",
    color: "bg-amber-100 text-amber-700",
  },
  {
    name: "Sofía Almeida",
    location: "Las Palmas de G.C.",
    text: "Maruchy es una artista y una persona fantástica. Sus talleres son terapéuticos, te desconectas completamente. El ambiente que crea es de lo mejor que he vivido en un taller.",
    stars: 5,
    avatar: "SA",
    color: "bg-teal-100 text-teal-700",
  },
  {
    name: "Elena Torres",
    location: "Gran Canaria",
    text: "Regalé una corona floral para decoración del salón y el resultado fue espectacular. La entrega fue puntual y el embalaje muy cuidado. Una artesana de verdad.",
    stars: 5,
    avatar: "ET",
    color: "bg-pink-100 text-pink-700",
  },
];
---
<section id="testimonios" class="py-24 lg:py-32 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="section-tag">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        Testimonios
      </span>
      <h2 class="section-heading mb-4">
        Lo que dicen quienes<br />
        <em class="text-brand-600">ya han vivido la experiencia</em>
      </h2>
    </div>

    <!-- Grid de testimonios -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <blockquote
          class="reveal card bg-warm-50 border border-warm-100 p-6 hover:-translate-y-0.5"
          style={`animation-delay: ${i * 80}ms`}
        >
          <!-- Estrellas -->
          <div class="flex gap-0.5 mb-4" aria-label={`${t.stars} estrellas de 5`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Comilla decorativa -->
          <svg class="w-8 h-8 text-brand-200 mb-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <p class="text-warm-600 text-sm leading-relaxed mb-6 italic">{t.text}</p>

          <!-- Autor -->
          <footer class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm ${t.color} flex-shrink-0`} aria-hidden="true">
              {t.avatar}
            </div>
            <div>
              <cite class="not-italic font-semibold text-warm-800 text-sm">{t.name}</cite>
              <div class="text-xs text-warm-400 flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                {t.location}
              </div>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <!-- Media badge de confianza -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-8 reveal">
      <div class="flex items-center gap-3 bg-warm-50 border border-warm-200 rounded-2xl px-5 py-3">
        <div class="flex -space-x-2">
          {['AG', 'CR', 'LM'].map((av, i) => (
            <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ring-2 ring-white ${['bg-brand-100 text-brand-700', 'bg-purple-100 text-purple-700', 'bg-rose-100 text-rose-700'][i]}`} aria-hidden="true">{av}</div>
          ))}
        </div>
        <div>
          <div class="text-sm font-semibold text-warm-800">+200 alumnas satisfechas</div>
          <div class="flex items-center gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
            <span class="text-xs text-warm-500 ml-1">5.0 de media</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
