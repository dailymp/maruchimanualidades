---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Mis pedidos — Maruchy Manualidades"
  description="Consulta el estado de tus pedidos en Maruchy Manualidades introduciendo tu email."
>
  <main class="min-h-screen bg-[linear-gradient(180deg,#fffaf7_0%,#f5eee5_100%)] pt-28 pb-16 px-6 md:px-12">
    <div class="max-w-2xl mx-auto">

      <div class="mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-[#ad8478] hover:text-[#b68172] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Volver a la tienda
        </a>
        <h1 class="mt-4 font-display text-4xl text-[#4d342f]">Mis pedidos</h1>
        <p class="mt-2 text-[#6f5750]">Introduce tu email para ver el estado de tus pedidos.</p>
      </div>

      <!-- Formulario de búsqueda -->
      <div class="rounded-3xl border border-white/70 bg-white/80 shadow-card backdrop-blur-sm p-6 md:p-8">
        <form id="search-form" class="flex gap-3" novalidate>
          <input
            id="email-input"
            type="email"
            required
            autocomplete="email"
            placeholder="tu@email.com"
            class="flex-1 rounded-xl border border-warm-200 bg-white px-4 py-3 text-sm text-[#4d342f] placeholder-warm-300 focus:border-[#b68172] focus:outline-none focus:ring-2 focus:ring-[#b68172]/20 transition-colors"
          />
          <button
            type="submit"
            id="search-btn"
            class="rounded-full bg-[#4d342f] px-6 py-3 text-sm font-medium text-white shadow-soft transition-all hover:bg-[#3a2520] disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap"
          >
            Buscar
          </button>
        </form>
        <p id="search-error" class="hidden mt-3 text-sm text-red-600"></p>
      </div>

      <!-- Resultados -->
      <div id="results" class="mt-6 space-y-4 hidden"></div>

      <!-- Estado vacío -->
      <div id="empty-state" class="hidden mt-8 text-center py-12">
        <div class="w-16 h-16 bg-[#f5eee5] rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-[#ad8478]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4"/>
          </svg>
        </div>
        <p class="text-[#6f5750] font-medium">No encontramos pedidos con ese email.</p>
        <p class="text-sm text-[#ad8478] mt-1">¿Dudas? Escríbenos por WhatsApp.</p>
        <a
          href="https://wa.me/34676053518"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 rounded-full bg-[#25D366] text-white text-sm font-medium px-6 py-3 hover:bg-[#1ebe5d] transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Hablar con Maruchy
        </a>
      </div>

    </div>
  </main>
</Layout>

<script>
  const STATE_LABELS: Record<string, { label: string; classes: string }> = {
    draft:  { label: 'Recibido',      classes: 'bg-yellow-50 text-yellow-700 border-yellow-200' },
    sent:   { label: 'Recibido',      classes: 'bg-yellow-50 text-yellow-700 border-yellow-200' },
    sale:   { label: 'En preparación', classes: 'bg-blue-50 text-blue-700 border-blue-200' },
    done:   { label: 'Completado',    classes: 'bg-green-50 text-green-700 border-green-200' },
    cancel: { label: 'Cancelado',     classes: 'bg-red-50 text-red-600 border-red-200' },
  };

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function stripHtml(s: string): string {
    const doc = new DOMParser().parseFromString(s, 'text/html');
    return doc.body.textContent?.trim() ?? '';
  }

  function formatDate(iso: string): string {
    const d = new Date(iso.replace(' ', 'T') + 'Z');
    return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function renderOrders(orders: {
    id: number; name: string; date: string; state: string;
    total: number; note: string | false;
    lines: { name: string; quantity: number; price_unit: number; price_subtotal: number }[];
  }[]) {
    const container = document.getElementById('results')!;
    const empty = document.getElementById('empty-state')!;

    if (!orders.length) {
      container.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');
    container.classList.remove('hidden');

    container.innerHTML = orders.map(order => {
      const st = STATE_LABELS[order.state] ?? { label: order.state, classes: 'bg-warm-50 text-warm-600 border-warm-200' };
      const address = order.note ? stripHtml(order.note).replace('Envío: ', '') : '';
      return `
        <div class="rounded-3xl border border-white/70 bg-white/80 shadow-card backdrop-blur-sm overflow-hidden">
          <div class="px-6 py-5 flex flex-wrap items-start justify-between gap-3 border-b border-warm-100">
            <div>
              <p class="font-mono text-lg font-bold text-[#4d342f]">${esc(order.name)}</p>
              <p class="text-sm text-[#ad8478] mt-0.5">${formatDate(order.date)}</p>
              ${address ? `<p class="text-xs text-[#ad8478] mt-0.5">${esc(address)}</p>` : ''}
            </div>
            <div class="flex flex-col items-end gap-2">
              <span class="border text-xs font-semibold px-3 py-1 rounded-full ${st.classes}">${st.label}</span>
              <span class="font-display text-xl font-bold text-[#4d342f]">${order.total.toLocaleString('es-ES', { minimumFractionDigits: 2 })} €</span>
            </div>
          </div>
          <ul class="divide-y divide-warm-50">
            ${order.lines.map(line => `
              <li class="px-6 py-3 flex justify-between items-center gap-4 text-sm">
                <span class="text-[#4d342f]">${esc(line.name)} <span class="text-[#ad8478]">× ${line.quantity}</span></span>
                <span class="font-medium text-[#4d342f] whitespace-nowrap">${line.price_subtotal.toLocaleString('es-ES', { minimumFractionDigits: 2 })} €</span>
              </li>
            `).join('')}
          </ul>
        </div>
      `;
    }).join('');
  }

  const form = document.getElementById('search-form') as HTMLFormElement;
  const emailInput = document.getElementById('email-input') as HTMLInputElement;
  const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('search-error')!;

  // Pre-rellenar email si viene de la URL (?email=...)
  const params = new URLSearchParams(window.location.search);
  const preEmail = params.get('email');
  if (preEmail) {
    emailInput.value = preEmail;
    form.dispatchEvent(new Event('submit'));
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    document.getElementById('results')!.classList.add('hidden');
    document.getElementById('empty-state')!.classList.add('hidden');

    const email = emailInput.value.trim();
    if (!email) return;

    searchBtn.disabled = true;
    searchBtn.textContent = 'Buscando...';

    try {
      const res = await fetch('/api/orders-by-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();
      if (!res.ok || data.error) throw new Error(data.error ?? 'Error');

      renderOrders(data.orders);
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Error al buscar pedidos.';
      errorEl.classList.remove('hidden');
    } finally {
      searchBtn.disabled = false;
      searchBtn.textContent = 'Buscar';
    }
  });
</script>
