---
import Layout from '../layouts/Layout.astro';
const orderRef = Astro.url.searchParams.get('ref');
const customerEmail = Astro.url.searchParams.get('email') ?? '';
---

<Layout title="Pedido confirmado — Maruchy Manualidades">
  <main class="min-h-screen bg-gradient-to-br from-brand-50 via-cream-50 to-warm-50 flex items-center justify-center px-6 py-24">
    <div class="w-full max-w-lg bg-white rounded-3xl shadow-card p-10 text-center space-y-6">

      <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mx-auto">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <div class="space-y-2">
        <h1 class="font-display text-3xl text-warm-900">¡Pedido confirmado!</h1>
        {orderRef && (
          <p class="text-sm font-mono text-brand-600 bg-brand-50 rounded-lg px-3 py-1.5 inline-block">
            Pedido #{orderRef}
          </p>
        )}
        <p class="text-warm-500 leading-relaxed">
          Maruchy ya ha recibido tu pedido y se pondrá en contacto contigo pronto para coordinar la entrega. Pagarás al recibirlo.
        </p>
      </div>

      <div class="bg-brand-50 rounded-2xl p-5 text-sm text-brand-800 space-y-1 text-left">
        <p class="font-semibold mb-2">¿Qué pasa ahora?</p>
        <p>1. Maruchy confirma tu pedido y lo prepara con cariño.</p>
        <p>2. Recibirás un aviso cuando sea enviado.</p>
        <p>3. Pagas al repartidor cuando lo recibas.</p>
      </div>

      <a
        href="https://wa.me/34676053518"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] text-white font-medium px-8 py-4 hover:bg-[#1ebe5d] transition-all duration-200 shadow-soft"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hablar con Maruchy
      </a>

      <a href="/" class="block text-sm text-warm-400 hover:text-warm-600 transition-colors">
        Volver a la tienda
      </a>

      <a
        href={`/mis-pedidos${customerEmail ? `?email=${encodeURIComponent(customerEmail)}` : ''}`}
        class="block text-sm text-[#b68172] hover:text-[#a06c5e] transition-colors font-medium"
      >
        Ver todos mis pedidos →
      </a>
    </div>
  </main>
</Layout>
